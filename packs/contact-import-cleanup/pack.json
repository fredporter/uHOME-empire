{
  "manifest_version": "v2.0.4",
  "pack_id": "contact-import-cleanup",
  "label": "Contact Import Cleanup",
  "category": "contacts",
  "summary": "Starter contact import cleanup pack for reviewed field normalization and CRM-facing sync handoff.",
  "channels": [
    "contacts",
    "hubspot-sync"
  ],
  "inputs": [
    {
      "name": "import_batch_name",
      "type": "text",
      "required": true,
      "description": "Readable import batch label."
    },
    {
      "name": "cleanup_notes",
      "type": "markdown",
      "required": true,
      "description": "Operator notes for field cleanup and merge review."
    }
  ],
  "outputs": [
    {
      "name": "cleanup_preview",
      "type": "preview-report",
      "description": "Dry-run review of import cleanup work."
    },
    {
      "name": "contact_sync_package",
      "type": "sync-package",
      "description": "HubSpot-scoped sync package for approved contact operations."
    }
  ],
  "approval_mode": "manual-review",
  "dry_run_supported": true,
  "runtime": {
    "runtime_owner": "uHOME-server",
    "execution_mode": "local-runtime-with-provider-handoff",
    "container_jobs": [
      "hubspot-sync"
    ],
    "wizard_optional": true
  },
  "assets": {
    "templates": [
      "templates/cleanup-report.md"
    ],
    "sample_data": [
      "sample-data/preview-input.json"
    ],
    "docs": [
      "README.md"
    ]
  },
  "provider_adapters": [
    "hubspot-sync"
  ],
  "related_binders": [
    "#binder/contact-import-cleanup"
  ]
}
