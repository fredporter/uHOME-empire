{
  "manifest_version": "v2.0.4",
  "pack_id": "weekly-bulletin",
  "label": "Weekly Bulletin",
  "category": "messaging",
  "summary": "Starter recurring bulletin pack for a weekly update with preview-first messaging and CRM activity handoff.",
  "channels": [
    "email",
    "hubspot-sync"
  ],
  "inputs": [
    {
      "name": "bulletin_title",
      "type": "text",
      "required": true,
      "description": "Bulletin headline."
    },
    {
      "name": "bulletin_items",
      "type": "markdown",
      "required": true,
      "description": "Structured bulletin content."
    }
  ],
  "outputs": [
    {
      "name": "bulletin_preview",
      "type": "preview-report",
      "description": "Rendered bulletin content for review."
    },
    {
      "name": "bulletin_crm_package",
      "type": "sync-package",
      "description": "HubSpot-scoped sync package for approved bulletin activity."
    }
  ],
  "approval_mode": "test-then-approve",
  "dry_run_supported": true,
  "runtime": {
    "runtime_owner": "uHOME-server",
    "execution_mode": "local-runtime-with-provider-handoff",
    "container_jobs": [
      "hubspot-sync"
    ],
    "wizard_optional": true
  },
  "assets": {
    "templates": [
      "templates/bulletin.md"
    ],
    "sample_data": [
      "sample-data/preview-input.json"
    ],
    "docs": [
      "README.md"
    ]
  },
  "provider_adapters": [
    "hubspot-sync"
  ],
  "related_binders": [
    "#binder/weekly-bulletin"
  ]
}
